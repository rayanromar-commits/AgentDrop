# macOS Finder junk
.DS_Store

# Secrets — NEVER commit API keys.
.env
*.env
client_secret*.json
token.json

# Python virtual environment
venv/
.venv/

# Generated/working files
__pycache__/
*.pyc
database/*.db
media/
voiceover/output/
video/output/
review/pending/
review/approved/
review/rejected/

# Keep the footage library out of version control (big files)...
footage/*.mp4
footage/*.mov
# ...except the small, compressed cloud-ready clips (bg1.mp4, bg2.mp4, ...).
!footage/bg*.mp4
