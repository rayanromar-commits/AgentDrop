# macOS Finder junk
.DS_Store

# Secrets — NEVER commit API keys.
.env
*.env
client_secret*.json
# OAuth token files (google token.json, tiktok_token.json, etc.)
token.json
*token.json

# Python virtual environment
venv/
.venv/

# Generated/working files
__pycache__/
*.pyc
database/*.db
media/
voiceover/output/
video/output/
review/pending/
review/approved/
review/rejected/

# Keep the footage library out of version control (big files)...
footage/*.mp4
footage/*.mov
# ...except the small, compressed cloud-ready clips (bg1.mp4, bg2.mp4, ...).
!footage/bg*.mp4

# Compressed, render-ready footage (1080x1920, audio stripped). These are
# small enough to commit and are what the cloud uses (see footage_library).
# The raw 4K masters in footage/ stay ignored above.

# token backups (secrets)
token.json.bak
token.json*
