# Copy this file to a new file named ".env" and fill in your real values.
# The .env file is git-ignored, so your secrets stay private.
#
#   cp .env.example .env     <- run this once, then edit .env
#
# Do NOT put real keys in this .example file.

# --- Reddit API (Step 2) ---
# Get these at https://www.reddit.com/prefs/apps  (see README / chat steps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
# A short label identifying your app. Format convention:
# platform:appname:version (by /u/your_reddit_username)
REDDIT_USER_AGENT=script:agentdrop:v0.1 (by /u/your_username)

# --- ElevenLabs TTS (filled in at Step 4) ---
# ELEVENLABS_API_KEY=

# --- YouTube (set up at Step 8, uses a separate file) ---
